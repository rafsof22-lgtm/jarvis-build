AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=
AWS_TEXTRACT_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
