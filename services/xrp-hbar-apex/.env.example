# Required runtime
APP_ENV=production
BASE_URL=https://your-xrp-hbar-apex-service.up.railway.app
LOG_LEVEL=info
# Railway normally injects PORT automatically.
PORT=3000

# MCP auth. Never commit real values.
# Recommended production mode: bearer
MCP_AUTH_MODE=bearer
MCP_BEARER_TOKEN=
MCP_API_KEY=

# Optional future integrations. Do not commit real values.
OPENAI_API_KEY=
TRANSCRIPT_PROVIDER_API_KEY=
OCR_PROVIDER_API_KEY=
JOB_SIGNING_SECRET=
POSTGRES_URL=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=
GITHUB_TOKEN=
N8N_WEBHOOK_BASE_URL=
N8N_WEBHOOK_SECRET=
