TWELVE_DATA_API_KEY=
TIINGO_BASE_URL=https://api.tiingo.com
TIINGO_API_KEY=

# -----------------------------------------------------------------------------
# Transcription and OCR providers
# Local/manual mode works without these. Paid/free-key providers are optional.
# -----------------------------------------------------------------------------
TRANSCRIPT_PROVIDER=manual
TRANSCRIPT_PROVIDER_API_KEY=
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
REVAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=whisper-1
