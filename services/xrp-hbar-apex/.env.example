# XRP/HBAR Apex Intelligence OS environment template
# Copy values into Railway variables or a vault. Never commit real secrets.

# -----------------------------------------------------------------------------
# Required runtime
# -----------------------------------------------------------------------------
APP_ENV=production
BASE_URL=https://your-xrp-hbar-apex-service.up.railway.app
LOG_LEVEL=info
# Railway injects PORT automatically. Keep a local fallback only.
PORT=3000
SERVICE_NAME=xrp-hbar-intelligence
SERVICE_ROOT=services/xrp-hbar-apex
PUBLIC_SERVICE_PATH_PREFIX=/xrp-hbar-apex

# -----------------------------------------------------------------------------
# MCP auth
# -----------------------------------------------------------------------------
# Production recommended: bearer
MCP_AUTH_MODE=bearer
MCP_BEARER_TOKEN=
MCP_API_KEY=
MCP_ALLOWED_ORIGINS=
MCP_RATE_LIMIT_PER_MINUTE=60
JOB_SIGNING_SECRET=
WEBHOOK_SIGNING_SECRET=

# -----------------------------------------------------------------------------
# Safety gates - keep paper/read-only until explicitly upgraded
# -----------------------------------------------------------------------------
READ_ONLY_MODE=true
TRADING_MODE=paper
LIVE_TRADING_ENABLED=false
APPROVAL_REQUIRED=true
OWNER_APPROVAL_CHANNEL=manual
MAX_DAILY_API_SPEND_USD=0
MAX_DAILY_LLM_SPEND_USD=0
MAX_DAILY_TRADING_NOTIONAL_USD=0
ENABLE_SCHEDULED_SCANS=false
ENABLE_PROVIDER_TRANSCRIPTION=false
ENABLE_PROVIDER_OCR=false
ENABLE_PROVIDER_MARKET_DATA=false
ENABLE_PROVIDER_ONCHAIN_DATA=false
ENABLE_PROVIDER_SOCIAL_DATA=false
ENABLE_PROVIDER_NEWS_DATA=false
ENABLE_DATABASE_WRITES=false
ENABLE_GOOGLE_SHEETS_WRITES=false
ENABLE_GITHUB_WRITES=false
ENABLE_RAILWAY_MUTATIONS=false
ENABLE_TELEGRAM_ALERTS=false
ENABLE_SLACK_ALERTS=false
ENABLE_DISCORD_ALERTS=false

# -----------------------------------------------------------------------------
# Core tracker defaults
# -----------------------------------------------------------------------------
PRIMARY_ASSETS=XRP
SECONDARY_ASSETS=HBAR
WATCHLIST_ASSETS=XRP,HBAR,RLUSD,BTC,ETH,USDC
LOW_PRICE_CRYPTO_WATCHLIST=
LOW_PRICE_STOCK_WATCHLIST=
DEFAULT_TIMEZONE=Australia/Melbourne
DEFAULT_SCAN_MODE=free_public_first
SOURCE_HEALTH_MODE=strict
PROOF_GATE_MODE=direct_demand_first
ARCHIVE_IMPORT_MODE=manual

# -----------------------------------------------------------------------------
# Free/public-first XRP/XRPL sources
# -----------------------------------------------------------------------------
XRPL_NETWORK=mainnet
XRPL_RPC_URL=https://s1.ripple.com:51234
XRPL_RPC_FALLBACK_URL=https://xrplcluster.com
XRPL_WS_URL=wss://s1.ripple.com
XRPL_WS_FALLBACK_URL=wss://xrplcluster.com
XRPL_EXPLORER_BASE_URL=https://livenet.xrpl.org
XRPSCAN_BASE_URL=https://xrpscan.com
BITHOMP_BASE_URL=https://bithomp.com
XRPL_TO_BASE_URL=https://xrpl.to
XRPL_ORG_BASE_URL=https://xrpl.org
RIPPLE_BASE_URL=https://ripple.com
RIPPLE_INSIGHTS_RSS_URL=https://ripple.com/insights/feed/
RIPPLE_STABLECOIN_URL=https://ripple.com/solutions/stablecoin/

# -----------------------------------------------------------------------------
# Free/public-first HBAR/Hedera sources
# -----------------------------------------------------------------------------
HEDERA_NETWORK=mainnet
HEDERA_MIRROR_NODE_URL=https://mainnet-public.mirrornode.hedera.com
HEDERA_HASHSCAN_BASE_URL=https://hashscan.io/mainnet
HEDERA_DOCS_BASE_URL=https://docs.hedera.com
HEDERA_BASE_URL=https://hedera.com
HEDERA_BLOG_RSS_URL=https://hedera.com/blog/rss.xml

# -----------------------------------------------------------------------------
# Free/public-first market and DeFi data
# -----------------------------------------------------------------------------
COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
COINPAPRIKA_API_BASE_URL=https://api.coinpaprika.com/v1
DEFILLAMA_API_BASE_URL=https://api.llama.fi
DEFILLAMA_STABLECOINS_API_BASE_URL=https://stablecoins.llama.fi
YAHOO_FINANCE_BASE_URL=https://query1.finance.yahoo.com
BINANCE_API_BASE_URL=https://api.binance.com
KRAKEN_API_BASE_URL=https://api.kraken.com
COINBASE_EXCHANGE_API_BASE_URL=https://api.exchange.coinbase.com
BITSTAMP_API_BASE_URL=https://www.bitstamp.net/api/v2
UPHOLD_API_BASE_URL=https://api.uphold.com

# -----------------------------------------------------------------------------
# Optional market/on-chain paid or free-key APIs
# Leave blank until approved and connected.
# -----------------------------------------------------------------------------
COINMARKETCAP_API_KEY=
COINAPI_KEY=
CRYPTOCOMPARE_API_KEY=
COINGLASS_API_KEY=
MESSARI_API_KEY=
COINMETRICS_API_KEY=
