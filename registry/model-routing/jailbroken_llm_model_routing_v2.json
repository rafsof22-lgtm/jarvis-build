{
  "policy_id": "JARVIS-JAILBROKEN-LLM-MODEL-ROUTING-V2",
  "version": "2.0.0",
  "user_facing_name": "Jailbroken LLM Model Routing",
  "canonical_meaning": "Select the least unnecessarily restrictive approved and compliant route that satisfies the task, data, capability, quality, cost and privacy requirements.",
  "non_bypass_rule": "The policy never bypasses law, platform or provider terms, Jarvis safety, privacy, security, approval gates, credentials, billing, production controls, financial controls or clinical/device controls.",
  "modes": [
    "normal",
    "lowest_restriction",
    "local_sovereign",
    "offline_private",
    "highest_parameter_local",
    "fast_local",
    "free_first",
    "cheapest_effective",
    "quality_first",
    "parallel_intelligence",
    "manual_model"
  ],
  "selection_order": [
    "deterministic_no_llm",
    "verified_cache",
    "approved_local_model",
    "approved_free_route_for_non_sensitive_data",
    "cheapest_route_that_passes_task_evaluation",
    "balanced_specialist",
    "premium_specialist",
    "one_to_eight_model_panel_when_expected_value_justifies_cost",
    "independent_output_verifier"
  ],
  "self_hosted_runtimes": ["ollama", "llama.cpp", "vllm"],
  "self_hosted_default": "ollama",
  "highest_parameter_rule": "Choose the largest officially recorded approved model that fits declared memory, context, capability, licence, digest and evaluation requirements. Unknown parameter counts remain UNKNOWN and are never guessed.",
  "parallel_panel": {
    "minimum_models": 1,
    "maximum_models": 8,
    "default_models": 3,
    "independent_first_pass": true,
    "disagreements_preserved": true,
    "early_stop": true,
    "budget_preflight": true,
    "private_chain_of_thought_exposure": false
  },
  "data_rules": {
    "restricted": "local or approved private route only",
    "free_tier_sensitive_data": false,
    "secret_values": false,
    "provider_retention_and_training_policy_check": true,
    "redaction_and_minimisation": true
  },
  "model_registry_required_fields": [
    "model_id",
    "provider",
    "runtime",
    "version_or_digest",
    "licence",
    "total_parameters",
    "active_parameters",
    "parameter_source",
    "estimated_memory_gb",
    "context_tokens",
    "capabilities",
    "data_policy",
    "cost",
    "latency",
    "task_evaluations",
    "approved_tasks",
    "blocked_data_classes",
    "last_verified"
  ],
  "approval_gates": [
    "new provider credentials",
    "paid usage or auto-reload",
    "sensitive cloud routing",
    "production route change",
    "model download with unreviewed licence or digest",
    "parallel panel above configured AUD threshold"
  ],
  "required_tests": [
    "local_default",
    "cloud_disabled_by_default",
    "manual_route_must_be_configured",
    "highest_parameter_fit",
    "unknown_parameter_not_inferred",
    "one_to_eight_panel_limit",
    "budget_stop",
    "restricted_data_route",
    "partial_failure",
    "disagreement_preservation",
    "rollback"
  ],
  "runtime_state": "DETERMINISTIC_SELECTION_IMPLEMENTED_PROVIDER_CLIENTS_NOT_CONNECTED_BY_THIS_TRANCHE",
  "rollback": "Restore the previous router modules and disable new routing modes; no provider or model state is mutated by deterministic selection."
}
