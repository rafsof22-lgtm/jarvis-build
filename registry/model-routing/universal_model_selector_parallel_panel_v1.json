    "invent_unknown_models": false,
    "routes_without_inventory_are_visible_blockers": true
  },
  "parallel_panel": {
    "minimum_models": 2,
    "maximum_models": 8,
    "roles": ["primary_reasoner", "source_researcher", "systems_architect", "domain_specialist", "security_and_safety_critic", "cost_and_efficiency_critic", "independent_verifier", "final_synthesiser"],
    "raw_response_retention": "REQUIRED",
    "response_proof_key": "selector_id + sha256",
    "claim_and_evidence_matrix": "REQUIRED",
    "contradiction_register": "REQUIRED",
    "omission_register": "REQUIRED",
    "majority_vote_is_proof": false,
    "best_supported_consolidation": true,
    "universal_zero_error_or_zero_gap_claim": false,
    "verified_scope_label": "NO_KNOWN_GAPS_WITHIN_VERIFIED_PANEL_SCOPE"
  },
  "shared_surfaces": ["jarvis_pop", "command_centre", "framework_editor", "spec_editor", "workflow_builder", "stack_and_architecture_editor", "orchestrator_editor", "skill_editor", "agent_editor", "prompt_library", "source_analyst", "test_and_evaluation_console", "deployment_wizard"],
  "implementation": {
    "catalogue_and_panel": "jarvis_model_router/selector.py",
    "assistant_adapter": "src/jarvis_evolution/parallel_assistant_v2.py",
    "command_centre_panel": "jarvis_command_centre/model_control_panel.py",
    "tests": "tests/test_universal_model_selector_chathub_v3.py",
    "verifier": "scripts/verify_universal_model_selector_chathub_v3.py"
  },
  "truth_boundary": "This release implements model inventory, selection, panel planning and synthesis evidence contracts. Live provider calls require configured provider adapters, approved credentials, budget preflight and runtime evidence."
}
