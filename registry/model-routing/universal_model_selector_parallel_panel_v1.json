  "status": "IMPLEMENTED_NOT_INTEGRATED",
  "purpose": "Expose every concrete connected model ID through one shared selector contract and run governed parallel panels of two to eight models.",
  "model_inventory": {
    "default_model_env": "Use each route's existing default_model_env.",
    "all_models_env_pattern": "JARVIS_<ROUTE_NAME>_MODELS",
