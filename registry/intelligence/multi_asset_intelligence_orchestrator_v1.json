{
  "contract_id": "JARVIS-MULTI-ASSET-INTELLIGENCE-ORCHESTRATOR-V1",
  "version": "1.0.0",
  "effective_date": "2026-07-21",
  "state": "IMPLEMENTED_NOT_INTEGRATED",
  "purpose": "Coordinate evidence-led intelligence gathering, milestone analysis, ceiling scenarios, recommendations and Knowledge Fabric exports across separately governed XRP, HBAR and future asset profiles.",
  "trigger_aliases": {
    "UPDATE": ["update", "refresh", "recalculate", "sync asset intelligence"],
    "DEEP_SCAN": ["deep scan", "deepscan", "deep research", "exhaustive scan"],
    "ALL_INTELLIGENCE": ["all intelligence", "all intelligence gathering", "full intelligence", "apex scan", "scan all assets"]
  },
  "trigger_execution": {
    "UPDATE": {
      "source_budget_mode": "standard",
      "fan_out": "all_active_asset_profiles_unless_scoped",
      "simultaneous_workstreams": [
        "current_source_refresh",
        "new_source_discovery",
        "claim_reverification",
        "milestone_recalculation",
        "ceiling_scenario_recalculation",
        "catalyst_and_trigger_refresh",
        "risk_and_invalidation_refresh",
        "discrepancy_detection",
        "recommendation_refresh",
        "knowledge_fabric_delta_export",
        "progress_and_gap_update"
      ]
    },
    "DEEP_SCAN": {
      "source_budget_mode": "deep",
      "fan_out": "all_active_asset_profiles_unless_scoped",
      "includes_update": true,
      "simultaneous_workstreams": [
        "expanded_query_families",
        "upstream_primary_source_search",
        "not_yet_found_source_discovery",
        "historical_lineage_reconciliation",
        "contradiction_and_adverse_case_search",
        "direct_demand_pathway_analysis",
        "market_structure_and_liquidity_analysis",
        "multi_model_independent_analysis",
        "cross_asset_comparison",
        "best_actionable_recommendations",
        "knowledge_fabric_full_export",
        "progress_and_gap_update"
      ]
    },
    "ALL_INTELLIGENCE": {
      "source_budget_mode": "apex",
      "fan_out": "every_active_asset_profile_and_cross_asset_layer",
      "includes_update": true,
      "includes_deep_scan": true,
      "run_independent_asset_workstreams_in_parallel": true,
      "preserve_asset_separation": true,
      "merge_only_at_cross_asset_synthesis": true,
      "maximum_sources_per_asset_per_run": 100,
      "allow_source_registry_growth_beyond_100_over_time": true,
      "simultaneous_workstreams": [
        "all_update_workstreams",
        "all_deep_scan_workstreams",
        "video_and_social_intelligence",
        "developer_and_repository_intelligence",
        "regulatory_and_legal_intelligence",
        "institutional_and_filing_intelligence",
        "macro_and_geopolitical_intelligence",
        "onchain_or_market_microstructure_intelligence",
        "forecast_and_ceiling_stress_tests",
        "bull_base_bear_and_failure_scenarios",
        "source_gap_exhaustion",
        "independent_verification",
        "ranked_recommendations",
        "command_centre_snapshot",
        "knowledge_fabric_export"
      ]
    }
  },
  "source_budget_policy": {
    "quick": {"minimum": 3, "maximum": 7},
    "standard": {"minimum": 8, "maximum": 25},
    "deep": {"minimum": 26, "maximum": 60},
    "apex": {"minimum": 61, "maximum": 100},
    "count_only_meaningful_sources": true,
    "no_duplicate_padding": true,
    "official_and_primary_sources_first": true,
    "negative_results_and_inaccessible_sources_logged": true,
    "continue_expanding_source_registry_between_runs": true,
    "source_ceiling_is_per_run_not_lifetime": true
  },
  "universal_source_families": [
    "official_project_or_company_sites",
    "official_documentation_and_developer_portals",
    "official_repositories_releases_issues_and_discussions",
    "regulators_courts_government_and_public_filings",
    "exchange_and_market_structure_sources",
    "onchain_explorers_and_network_telemetry",
    "institutional_filings_funds_etfs_and_custody_sources",
    "academic_and_peer_reviewed_research",
    "standards_bodies_central_banks_and_multilateral_institutions",
    "audited_financial_statements_and_earnings_materials",
    "reputable_market_data_and_analytics",
    "developer_ecosystem_and_security_advisories",
    "video_podcast_transcript_and_social_claim_sources",
    "credible_practitioner_and_community_sources_after_provenance_review",
    "competitor_substitute_and_counterfactual_sources",
    "historical_archives_and_user_authorised_source_packs"
  ],
  "source_discovery_requirements": {
    "generate_asset_specific_query_families": true,
    "search_entity_aliases_and_legacy_names": true,
    "search_both_supporting_and_adverse_evidence": true,
    "search_for_new_databases_apis_tools_and_repositories": true,
    "search_citations_and_upstream_sources": true,
    "record_queries_dates_result_counts_exclusions_and_blind_spots": true,
    "deduplicate_by_canonical_source_and_claim": true,
    "freshness_rules_are_asset_and_claim_specific": true
  },
  "shared_intelligence_pipeline": [
    "intent_and_asset_scope_lock",
    "profile_and_source_registry_load",
    "source_budget_lock",
    "parallel_source_discovery",
    "source_capture_hash_timestamp_and_provenance",
    "claim_and_metric_extraction",
    "authority_freshness_and_conflict_scoring",
    "asset_specific_fundamental_analysis",
    "direct_value_capture_or_demand_pathway_analysis",
    "market_structure_liquidity_supply_and_dilution_analysis",
    "milestone_and_dynamic_ceiling_scenarios",
    "catalyst_trigger_risk_and_invalidation_analysis",
    "historical_forecast_accuracy_and_discrepancy_update",
    "independent_model_or_rule_verification",
    "ranked_recommendations_and_watch_actions",
    "knowledge_fabric_and_command_centre_export",
    "progress_gap_test_evidence_and_rollback_update"
  ],
  "required_output_layers": [
    "executive_outcome",
    "current_verified_state",
    "what_changed",
    "source_denominator_and_coverage",
    "milestone_table",
    "dynamic_ceiling_scenarios",
    "direct_value_capture_analysis",
    "catalysts_and_triggers",
    "risks_and_invalidation_conditions",
    "conflicts_and_discrepancies",
    "bull_base_bear_failure_scenarios",
    "ranked_recommendations",
    "what_to_watch_next",
    "knowledge_fabric_records",
    "progress_tracker_and_open_loops"
  ],
  "forecast_truth_policy": {
    "separate_unconditional_probability": true,
    "separate_scenario_consistency_score": true,
    "separate_trigger_activation_score": true,
    "separate_market_implied_probability_when_available": true,
    "never_label_ceiling_as_prediction": true,
    "show_assumptions_and_required_capital_or_demand": true,
    "show_invalidation_conditions": true,
    "historical_forecasts_must_link_to_later_outcomes": true,
    "no_guaranteed_price_or_return_claims": true
  },
  "dynamic_ceiling_engine": {
    "enabled_for_every_asset": true,
    "ceiling_definition": "A family of mathematically and economically constrained scenario ceilings, not a single promised maximum price.",
    "required_models": [
      "fully_diluted_value_or_market_cap_constraint",
      "circulating_float_constraint",
      "liquidity_and_slippage_constraint",
      "capital_inflow_and_reflexivity_constraint",
      "value_capture_or_direct_demand_constraint",
      "velocity_turnover_or_holding_duration_constraint",
      "supply_dilution_unlock_or_emission_constraint",
      "competitive_substitution_constraint",
      "macro_liquidity_and_regulatory_constraint",
      "historical_analogue_and_extreme_stress_constraint"
    ],
    "required_ceiling_bands": [
      "credible_cycle_ceiling",
      "high_adoption_ceiling",
      "extreme_tail_ceiling",
      "theoretical_mechanical_ceiling",
      "invalid_or_economically_incoherent_region"
    ],
    "recalculate_on_every_update": true
  },
  "asset_onboarding": {
    "supported_classes": ["crypto", "stock", "etf", "commodity", "fx", "index", "property", "macro_or_rate_instrument"],
    "profile_template": "registry/intelligence/asset_profile_template_v1.json",
    "require_unique_asset_thesis_and_value_capture_model": true,
    "require_unique_milestones_and_ceiling_inputs": true,
    "require_unique_source_families_and_aliases": true,
    "require_unique_risks_competitors_and_invalidation_conditions": true,
    "new_profiles_default_to_research_only": true,
    "activate_after_schema_validation_and_source_plan_review": true
  },
  "model_and_agent_orchestration": {
    "deterministic_tools_first": true,
    "local_and_free_first": true,
    "independent_roles": [
      "source_scout",
      "primary_source_verifier",
      "asset_domain_analyst",
      "market_structure_analyst",
      "direct_value_capture_analyst",
      "forecast_and_ceiling_analyst",
      "risk_and_adverse_case_analyst",
      "historical_discrepancy_analyst",
      "cost_and_data_access_analyst",
      "independent_verifier",
      "final_synthesiser"
    ],
    "parallel_model_panel_minimum": 1,
    "parallel_model_panel_maximum": 8,
    "preserve_disagreements": true,
    "private_chain_of_thought_not_required_or_exposed": true
  },
  "knowledge_fabric_export": {
    "append_only": true,
    "raw_source_pointer_preserved": true,
    "canonical_claim_and_requirement_records": true,
    "asset_profile_and_run_ids_required": true,
    "source_hash_timestamp_freshness_and_authority_required": true,
    "supersession_conflict_and_invalidation_links_required": true,
    "forecast_snapshot_and_outcome_linking_required": true,
    "recommended_collections": [
      "asset_profiles",
      "asset_sources",
      "asset_claims",
      "asset_metrics",
      "asset_milestones",
      "asset_ceiling_scenarios",
      "asset_catalysts",
      "asset_risks",
      "asset_forecasts",
      "asset_forecast_outcomes",
      "asset_recommendations",
      "asset_discrepancies",
      "asset_run_manifests"
    ]
  },
  "execution_boundary": {
    "research_only_and_paper_first": true,
    "no_trade_execution": true,
    "no_money_movement": true,
    "no_custody_changes": true,
    "no_personalised_regulated_advice_claim": true,
    "production_or_paid_source_activation_requires_separate_approval": true,
    "no_hidden_continuous_monitoring_claim": true
  },
  "rollback": "Disable the multi-asset orchestrator feature flag and revert its pull request. Preserve all prior XRP/HBAR histories and independent asset profiles."
}
