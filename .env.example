# Jarvis runtime mode
JARVIS_ENV=
JARVIS_LOG_LEVEL=
JARVIS_ROUTER_DEFAULT_ROUTE=
JARVIS_ROUTER_ALLOW_CLOUD=

# Optional cloud model routes. Leave blank unless configured in repository or host secrets.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
OPENROUTER_DEFAULT_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_DEFAULT_MODEL=
KIMI_API_KEY=
KIMI_BASE_URL=
KIMI_DEFAULT_MODEL=
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_DEFAULT_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=

# Local zero-token fallback routes
OLLAMA_BASE_URL=
OLLAMA_DEFAULT_MODEL=
LLAMACPP_BASE_URL=
LLAMACPP_DEFAULT_MODEL=

# Deployment readiness gates. Store real values only in GitHub/provider secrets.
JARVIS_DEPLOY_TARGET=
JARVIS_HEALTHCHECK_URL=
ORACLE_HOST=
ORACLE_SSH_USER=
ORACLE_SSH_PORT=
ORACLE_SSH_PRIVATE_KEY=
ORACLE_DEPLOY_PATH=
VPS_HOST=
VPS_SSH_USER=
VPS_SSH_PORT=
VPS_SSH_PRIVATE_KEY=
VPS_DEPLOY_PATH=
