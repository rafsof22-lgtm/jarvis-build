# Jarvis repo-level environment template
# Do not commit real secrets, tokens, OAuth material, private keys, cookies, or production values.
# Store real values in GitHub Actions Secrets, Railway variables, n8n credentials, or an approved vault.

# -----------------------------------------------------------------------------
# GitHub Actions Google-family secret alias inputs
# -----------------------------------------------------------------------------
# These names support the secret-preflight workflow only. Leave blank locally.
# GitHub Actions should read real values through secrets.NAME references.
# GitHub stores repository secret names uppercase even when typed as Google or Google2.
GOOGLE_SECRET_RAW=
GOOGLE2_SECRET_RAW=

# Candidate GitHub Actions secret names requested by the user.
# If used locally for dry-run validation, keep values out of commits and logs.
GOOGLE=
GOOGLE2=
GMAIL=

# Conventional explicit Google/Gmail/Drive/Calendar secret names.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_API_KEY=
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Jarvis runtime mode
# -----------------------------------------------------------------------------
JARVIS_ENV=
JARVIS_LOG_LEVEL=
JARVIS_ROUTER_DEFAULT_ROUTE=
JARVIS_ROUTER_ALLOW_CLOUD=

# Optional cloud model routes. Leave blank unless configured in repository or host secrets.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
OPENROUTER_DEFAULT_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_DEFAULT_MODEL=
KIMI_API_KEY=
KIMI_BASE_URL=
KIMI_DEFAULT_MODEL=
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_DEFAULT_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=

# Local zero-token fallback routes
OLLAMA_BASE_URL=
OLLAMA_DEFAULT_MODEL=
LLAMACPP_BASE_URL=
LLAMACPP_DEFAULT_MODEL=

# Deployment readiness gates. Store real values only in GitHub/provider secrets.
JARVIS_DEPLOY_TARGET=
JARVIS_HEALTHCHECK_URL=
ORACLE_HOST=
ORACLE_SSH_USER=
ORACLE_SSH_PORT=
ORACLE_SSH_PRIVATE_KEY=
ORACLE_DEPLOY_PATH=
VPS_HOST=
VPS_SSH_USER=
VPS_SSH_PORT=
VPS_SSH_PRIVATE_KEY=
VPS_DEPLOY_PATH=

# Existing module-level templates may define additional service-specific names under services/**/.env.example.
