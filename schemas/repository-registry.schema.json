{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.raf/schemas/repository-registry.schema.json",
  "title": "Jarvis Repository Registry",
  "type": "object",
  "required": ["schema_version", "generated_at", "repositories"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "generated_at": {"type": "string", "format": "date-time"},
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["repository_id", "full_name", "visibility", "default_branch", "role", "module_status", "blockers"],
        "properties": {
          "repository_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
          "full_name": {"type": "string", "pattern": "^[^/]+/[^/]+$"},
          "visibility": {"enum": ["public", "private", "internal"]},
          "default_branch": {"type": "string"},
          "role": {"type": "string"},
          "owner_module": {"type": "string"},
          "service_roots": {"type": "array", "items": {"type": "string"}},
          "deployment_ids": {"type": "array", "items": {"type": "string"}},
          "contract_endpoint": {"type": ["string", "null"]},
          "module_status": {"enum": ["proven", "operational", "partial", "scaffold", "blocked", "unknown", "retired"]},
          "last_verified_commit": {"type": ["string", "null"]},
          "evidence": {"type": "array", "items": {"type": "string"}},
          "blockers": {"type": "array", "items": {"type": "string"}},
          "tags": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
